{
  "name": "stellar-raven-codemode",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "description": "Remote MCP server exposing search + execute over a unified Stellar service catalog (Cloudflare Workers + Dynamic Worker isolates).",
  "scripts": {
    "prepare": "git config core.hooksPath scripts/git-hooks || true",
    "secrets:scan": "node scripts/scan-secrets.mjs",
    "dev": "wrangler dev --host localhost",
    "prebuild": "node scripts/build-micro-map.mjs",
    "build": "wrangler deploy --dry-run --outdir dist",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:smoke": "vitest run --config test/smoke/vitest.config.ts",
    "typegen": "wrangler types --include-runtime=false env.d.ts",
    "eval:compile": "node eval/compile-routing.mjs",
    "eval:discovery:agent": "node eval/discovery/run-agent-discovery.mjs",
    "eval:discovery:replay": "node eval/discovery/run-replay.mjs",
    "eval:vectorize:build": "node eval/vectorize/build-artifact.mjs",
    "eval:vectorize:run": "node eval/vectorize/run-frontier.mjs",
    "eval:vectorize:serve": "node eval/vectorize/serve-frontier.mjs",
    "micro-map:build": "node scripts/build-micro-map.mjs",
    "eval:routing": "node eval/run-routing.mjs",
    "eval:plan": "node eval/plan/grade-plan.mjs",
    "skills:bundle": "node scripts/bundle-skills.mjs",
    "spec:build": "node scripts/build-super-spec.mjs",
    "eval:selftest": "node eval/self-test.mjs",
    "eval:qa:compile": "node eval/qa/compile-qa.mjs",
    "eval:qa:selftest": "node eval/qa/judge.mjs --self-test",
    "eval:qa:lint": "node eval/qa/lint-corpus.mjs",
    "eval:qa:register": "node eval/qa/register-helper.mjs",
    "eval:qa": "node eval/qa/run-qa.mjs",
    "eval:playground": "node scripts/run-playground-semantic-eval.mjs",
    "eval:algolia-raven": "node scripts/eval-algolia-raven.mjs",
    "eval:partner-docs": "node scripts/eval-partner-docs.mjs",
    "algolia:rule-canary": "node scripts/check-algolia-rule-canary.mjs",
    "improvements:lint": "node scripts/improvements-lint.mjs",
    "improvements:probes": "node scripts/improvements-run-probes.mjs",
    "improvements:index": "node scripts/improvements-index.mjs",
    "site:fonts": "node scripts/gen-site-fonts.mjs",
    "site:og": "node scripts/gen-og.mjs",
    "site:globes": "node scripts/gen-globes.mjs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.94",
    "@ai-sdk/google": "^3.0.89",
    "@ai-sdk/openai": "^3.0.81",
    "@cloudflare/codemode": "0.4.2",
    "@cloudflare/workers-oauth-provider": "^0.8.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "acorn": "^8.17.0",
    "agents": "^0.17.3",
    "ai": "6.0.219",
    "workers-ai-provider": "3.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@huggingface/transformers": "4.2.0",
    "@cloudflare/vitest-pool-workers": "^0.18.0",
    "@cloudflare/workers-types": "^4.20260702.1",
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.107.0"
  }
}
