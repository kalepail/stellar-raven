{
  "id": "q-soroban-storage-migration",
  "question": "How should stored data be migrated when a Soroban contract upgrade changes its data structures?",
  "surface": [
    "stellarDocs.search_soroban_contract_docs",
    "skills.openzeppelin-stellar.upgrade-stellar-contracts",
    "skills.stellar-dev.smart-contracts"
  ],
  "golden": {
    "answer": "Updating a contract's Wasm keeps the contract address and storage; it does not rewrite stored values into a new schema. Version stored records and use either lazy migration on read/write or a controlled migration entrypoint that converts bounded batches. Keep old and new decoding paths only for the migration window, make the operation idempotent, test against production-shaped state, and retain rollback or pause controls. Large migrations should be batched to stay within transaction resources.",
    "keyFacts": [
      "A Wasm upgrade does not automatically transform existing contract storage.",
      "Versioned records can be migrated lazily or through a controlled explicit migration entrypoint.",
      "Large migrations should be idempotent and batched to fit transaction resource limits."
    ],
    "avoid": [
      "Uploading new Wasm automatically re-encodes all existing storage values.",
      "Every migration must fit into one transaction."
    ]
  },
