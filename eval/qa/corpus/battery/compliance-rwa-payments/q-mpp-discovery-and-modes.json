{
  "id": "q-mpp-discovery-and-modes",
  "question": "What is MPP on Stellar, what payment modes does it support, and how should an API advertise that agents can pay it?",
  "surface": [
    "skills.stellar-dev.agentic-payments",
    "stellarDocs.search_docs"
  ],
  "golden": {
    "answer": "MPP is an HTTP-402 payment-negotiation protocol. On Stellar, Charge settles SAC transfers per request and Session uses a funded unidirectional channel with cumulative off-chain commitments. Publish an OpenAPI 3.1 document, commonly /openapi.json, with x-payment-info.offers, but treat discovery metadata as advisory: the runtime 402 Challenge is authoritative for current price, token, network, expiry, and terms. Optional discovery includes MPPScan registration and the mpp.dev services registry, including the read-only https://mpp.dev/mcp/services surface. MPP and x402 are distinct protocols; expose separate adapters and never relabel payloads.",
    "keyFacts": [
      "MPP uses HTTP 402; Stellar Charge settles SAC transfers per request and Session uses cumulative off-chain channel commitments.",
      "Publish OpenAPI 3.1, commonly at /openapi.json, with x-payment-info.offers.",
      "Discovery metadata is advisory; the runtime 402 Challenge controls current price, token, network, expiry, and terms.",
      "MPPScan and the mpp.dev services registry, including https://mpp.dev/mcp/services, are optional discovery surfaces.",
      "MPP and x402 require separate adapters; their payloads must not be relabeled."
    ],
    "avoid": [
      "MPP Session requires a new on-chain transfer for every API call.",
      "Listing an API in an MPP directory automatically verifies all client payments."
    ],
    "notes": "Status-sensitive details are stated as of 2026-07-11; grade later sourced changes leniently and require dated primary evidence."
  },
