{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["contract", "authoredAt", "cases"],
  "properties": {
    "contract": { "const": "partner-docs-retrieval-v1" },
    "authoredAt": { "type": "string", "format": "date" },
    "note": { "type": "string" },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "partner", "question", "baseline", "candidateUrls", "facts"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "partner": { "enum": ["alchemy", "openzeppelin"] },
          "question": { "type": "string", "minLength": 1 },
          "baseline": {
            "oneOf": [
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["type", "id"],
                "properties": {
                  "type": { "const": "operation" },
                  "id": {
                    "enum": [
                      "stellarDocs.search_docs",
                      "stellarDocs.search_rpc_horizon_data_docs",
                      "stellarDocs.search_sdk_cli_tools_docs"
                    ]
                  }
                }
              },
              {
                "type": "object",
                "additionalProperties": false,
                "required": ["type", "id"],
                "properties": {
                  "type": { "const": "skill" },
                  "id": {
                    "enum": [
                      "skills.openzeppelin-stellar.setup-stellar-contracts",
                      "skills.openzeppelin-stellar.develop-secure-contracts"
                    ]
                  }
                }
              }
            ]
          },
          "candidateUrls": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "format": "uri" }
          },
          "facts": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  }
}
