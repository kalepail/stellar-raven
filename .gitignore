# secrets — never commit
.env
.dev.vars
.dev.vars.*

# raw real-user question pool — contains user PII + user-pasted secret keys; never commit
# (removed for privacy 2026-07-03; see eval/corpus/PROVENANCE.md)
eval/corpus/raven-golden-qa/jutsu/

# deps / build output
node_modules/
dist/
.wrangler/

# local OS/editor noise
.DS_Store

# generated types (npm run types)
env.d.ts
# local harness state (settings.local.json, worktrees) stays ignored;
# project skills are canonical in .agents/skills/ (read by Codex) and surfaced to
# Claude Code via the committed .claude/skills symlink -> ../.agents/skills.
# No trailing slash on the negation: it must re-include the symlink, not just a dir.
.claude/*
!.claude/skills

# eval run outputs — local-only; summaries live in the eval READMEs
eval/results/
eval/qa/results/
eval/agentic/results/
# run-routing's tsc-transpile fallback output (eval/run-routing.mjs)
eval/.build/

# local probe/measurement artifacts (round-5 adversarial probes etc.)
/tmp/
research/gauntlets/*.json
# real-user lane inputs/labels — PII-bearing source, never committed
/eval/local-lanes/
